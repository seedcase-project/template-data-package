[project]
name = "{{ github_repo }}"
version = "0.1.0"
# TODO: Add a description of the package.
description = ""
authors = [
  {name = "{{ author_given_name }} {{ author_family_name }}", email = "{{ author_email }}" },
  # TODO: Add more authors as needed.
]
maintainers = [
  {name = "{{ author_given_name }} {{ author_family_name }}", email = "{{ author_email }}" },
  # TODO: Add more maintainers as needed.
]
readme = "README.md"
{% if cc0_license %}
license = "MIT, CC0-1.0, AND CC-BY-4.0"
license-files = ["LICENSE-MIT.md", "LICENSE-CC0.md", "LICENSE-CC-BY-4.0.md"]
{% else %}
license = "MIT AND CC-BY-4.0"
license-files = ["LICENSE-MIT.md", "LICENSE-CC-BY-4.0.md"]
{% endif %}
requires-python = ">=3.12"

[project.urls]
issues = "https://github.com/{{ github_repo_spec }}/issues"
repository = "https://github.com/{{ github_repo_spec }}"
